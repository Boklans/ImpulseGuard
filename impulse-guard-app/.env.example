# Clerk Authentication
# Get keys from https://dashboard.clerk.com
# Use pk_test_* for development, pk_live_* for production
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# API Base URL
# Development: https://stage-api.impulseguard.app
# Production: https://api.impulseguard.app
EXPO_PUBLIC_API_URL=https://stage-api.impulseguard.app

# PostHog Analytics
# Get API key from https://us.posthog.com/project/settings
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxx
